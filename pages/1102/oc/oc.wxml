<wxs src="../../../stringUtil.wxs" module="utils" />
<view class="notice">
  <t-notice-bar content="Rclm 电阻不能小于 7.3kΩ，否则器件会有无法输出电压的风险" visible="{{true}}" prefixIcon="sound">
</t-notice-bar>
</view>
<!-- 根据过流保护点计算电阻 -->
<view class="input-data">
  <t-input cursor="{{utils.getLen(Iclm)}}" model:value="{{Iclm}}" placeholder="期望过流保护点 Iclm" type="digit" tips="期望过流保护点 Iclm，单位：A" />
</view>

<view class="compute-button">
  <t-button bind:tap="compute_click" size="large" theme="light" variant="outline" block>计算 CLM 对地电阻</t-button>
</view>
<view class="compute-result">
  <t-input disabled value="{{RclmResult}}" placeholder="CLM 引脚对地电阻" type="digit" tips="CLM 引脚对地电阻，单位：kohm" />
</view>

<!-- 根据电阻计算过流保护点 -->
<view class="input-data">
  <t-input cursor="{{utils.getLen(Rclm)}}" model:value="{{Rclm}}" placeholder="PCL 引脚对地电阻值" type="digit" tips="CLM 引脚对地电阻值 Rclm，单位：kohm" />
</view>

<view class="compute-button">
  <t-button bind:tap="compute_click" size="large" theme="light" variant="outline" block>计算过流保护值</t-button>
</view>
<view class="compute-result">
  <t-input disabled value="{{IclmResult}}" placeholder="过流保护点" type="digit" tips="过流保护点，单位：A" />
</view>