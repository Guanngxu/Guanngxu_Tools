<wxs src="../../../stringUtil.wxs" module="utils" />
<view class="input-data">
  <t-input cursor="{{utils.getLen(Css)}}" model:value="{{Css}}" placeholder="缓启动电容" type="digit" tips="缓启动电容，单位：nF" />
  <t-input cursor="{{utils.getLen(ChannelVout)}}" model:value="{{ChannelVout}}" placeholder="并联通道数" type="digit" tips="并联通道数，单位：个" />
</view>

<view class="compute-button">
  <t-button bind:tap="compute_click" size="large" theme="light" variant="outline" block>计算缓启动时间</t-button>
</view>
<view class="compute-result">
  <t-input disabled value="{{tss}}" placeholder="缓启动时间" type="digit" tips="缓启动时间，单位：ms" />
</view>