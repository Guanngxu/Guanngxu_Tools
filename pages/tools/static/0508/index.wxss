page {
  background-color: #f3f4f6;
  --td-brand-color: #0052D9;
}

.page-container {
  padding: 12px;
}

/* 顶部提示条 */
.notice-bar {
  display: flex;
  align-items: flex-start;
  background-color: #e0ebfd;
  padding: 10px 12px;
  border-radius: 6px;
  margin-bottom: 16px;
}

.notice-text {
  font-size: 12px;
  color: #0052D9;
  line-height: 1.5;
  margin-left: 8px;
}

/* 区块通用样式 */
.section {
  background-color: #ffffff;
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.title-left {
  display: flex;
  align-items: center;
}

.title-text {
  font-size: 16px;
  font-weight: 600;
  color: #333333;
  margin-left: 6px;
}

.image-wrapper {
  background-color: #f9f9f9;
  border-radius: 6px;
  padding: 8px;
  border: 1px dashed #dddddd;
}

/* 数据表格样式 */
.data-table {
  width: 100%;
  border: 1px solid #eeeeee;
  border-radius: 6px;
  overflow: hidden;
}

.tr {
  display: flex;
  width: 100%;
  border-bottom: 1px solid #eeeeee;
}

.tr:last-child {
  border-bottom: none;
}

/* 斑马纹背景 */
.tr.zebra {
  background-color: #fafbfc;
}

.table-header {
  background-color: #f3f4f6;
  font-weight: 600;
}

.th, .td {
  padding: 10px 8px;
  text-align: center;
  font-size: 13px;
  color: #333333;
  display: flex;
  align-items: center;
  justify-content: center;
}

.th {
  color: #666666;
  font-size: 12px;
}

/* 区分测试项列的字体权重 */
.td.item-name {
  font-weight: 500;
  justify-content: flex-start;
  text-align: left;
  padding-left: 12px;
}

/* 弹性宽度分配：测试项文字较长占2份，数值占1份 */
.flex-1 { flex: 1; }
.flex-2 { flex: 1.5; }

.safe-bottom {
  height: 40px;
}